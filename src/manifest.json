{
  "manifest_version": 3,
  "name": "Pretty New Tab",
  "author": "okiscape",
  "homepage_url": "https://github.com/okiscape/pretty-new-tab",
  "version": "1.0",
  "description": "Replaces the browser New-tab page with a new pretty one.",
  "chrome_url_overrides": {
    "newtab": "pages/index.html"
  },
  "options_page": "pages/settings.html",
  "permissions": [
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "pretty-new-tab@okiscape"
    }
  }
}
